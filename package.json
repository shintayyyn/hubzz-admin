{
  "name": "hubzz-admin",
  "version": "1.0.0",
  "description": "My doozie Nuxt.js project",
  "author": " ",
  "private": true,
  "scripts": {
    "dev": "nuxt",
    "dev:live": "API_URL=https://hubzz-api.herokuapp.com nuxt",
    "build": "nuxt build",
    "start": "nuxt start",
    "generate": "nuxt generate",
    "svg": "vsvg -s ./static/svg -t ./assets/svg",
    "heroku-postbuild": "npm run build",
    "lint": "eslint . --ignore-pattern 'node_modules/'"
  },
  "dependencies": {
    "@nuxtjs/auth": "^4.8.5",
    "@nuxtjs/axios": "^5.9.2",
    "cross-env": "^5.2.1",
    "dotenv": "^7.0.0",
    "highlight.js": "^9.17.1",
    "html2canvas": "^1.0.0-rc.5",
    "jspdf": "^1.5.3",
    "jspdf-autotable": "^3.2.11",
    "lodash.debounce": "^4.0.8",
    "moment": "^2.24.0",
    "nuxt": "^2.11.0",
    "socket.io-client": "^2.3.0",
    "validator": "^10.11.0",
    "vue": "^2.6.11",
    "vue-clickaway": "^2.2.2",
    "vue-quill-editor": "^3.0.6",
    "vue-router": "^3.1.3",
    "vue2-google-maps": "^0.10.7",
    "vuex": "^3.1.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^7.6.1",
    "@commitlint/config-conventional": "^7.6.0",
    "autoprefixer": "^8.6.4",
    "babel-eslint": "^10.0.3",
    "commitizen": "^3.1.2",
    "cz-conventional-changelog": "^2.1.0",
    "eslint": "^5.14.1",
    "eslint-plugin-nuxt": "^0.4.3",
    "eslint-plugin-vue": "^5.2.3",
    "husky": "^2.7.0",
    "lint-staged": "^8.2.1",
    "nodemon": "^1.19.4",
    "tailwindcss": "^1.1.4",
    "vue-svgicon": "^3.2.5"
  },
  "eslintConfig": {
    "extends": [
      "vue",
      "nuxt"
    ],
    "env": {
      "node": true,
      "browser": true
    },
    "rules": {
      "vue/max-attributes-per-line": "off",
      "vue/no-use-v-if-with-v-for": "off",
      "object-curly-newline": "off",
      "no-restricted-syntax": "off",
      "no-underscore-dangle": "off",
      "prefer-rest-params": "off",
      "no-shadow": "off",
      "no-multi-assign": "off",
      "consistent-return": "off",
      "no-param-reassign": "off",
      "strict": "off",
      "class-methods-use-this": "off",
      "no-nested-ternary": "off",
      "semi": [
        "error",
        "never"
      ],
      "space-before-function-paren": [
        "error",
        "always"
      ],
      "camelcase": "off",
      "max-len": "off",
      "no-console": "off",
      "no-plusplus": "off",
      "no-await-in-loop": "off",
      "func-names": "off",
      "global-require": "off",
      "import/no-dynamic-require": "off"
    }
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "git add",
      "eslint"
    ]
  }
}
